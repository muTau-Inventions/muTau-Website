# Normalize line endings
* text=auto

# Force LF for shell scripts and YAML
*.sh    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.py    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.md    text eol=lf

# Binary
*.pdf   binary
*.png   binary
*.jpg   binary
*.svg   binary